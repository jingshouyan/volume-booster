{
  "manifest_version": 3,
  "name": "Volume Booster",
  "version": "1.0.0",
  "description": "Boost audio volume beyond the browser's maximum limit",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Volume Booster"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
